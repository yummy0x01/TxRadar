# TxRadar environment variables (copy to .env and fill in).
# .env is gitignored — never commit real secrets or keypair paths with funds.

# --- Active profile: selects config/<profile>.toml (testnet | mainnet) ---
TXRADAR_PROFILE=testnet

# --- Secrets (kept out of the TOML profiles) ---
# Path to the fee-payer / signer keypair JSON (solana-keygen format).
TXRADAR_KEYPAIR_PATH=./keypairs/testnet.json

# Yellowstone gRPC auth token (from SolInfra / Triton / Helius).
TXRADAR_YELLOWSTONE_X_TOKEN=

# Solana RPC api_key (SEPARATE from the gRPC token — SolInfra issues a distinct
# key with RPC access). Appended to config.rpc.http_url as ?api_key=<key>.
TXRADAR_RPC_API_KEY=

# Google Gemini API key for the AI agent layer.
# Get a free key at https://aistudio.google.com/app/apikey — the free tier is
# enough to run the demo. Used with the default endpoint, OR with a
# compatible proxy/gateway together with GEMINI_BASE_URL below.
GEMINI_API_KEY=

# Optional: override the agent's Generative Language API endpoint. Leave blank
# to call generativelanguage.googleapis.com directly. Set to a Gemini-compatible
# gateway base URL (no trailing /v1beta/...) to route a gateway key through it.
GEMINI_BASE_URL=

# Optional Jito auth UUID (only if you have an approved rate-limit key).
TXRADAR_JITO_UUID=

# Log level (overrides config). e.g. info, txradar=debug
RUST_LOG=info,txradar=debug
